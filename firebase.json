{
  "functions": {
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run lint"
    ],
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.DS_Store",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/.well-known/apple-app-site-association",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    ],
    "redirects": [
      {
        "regex": "^/(?P<page>edit|edit-banner|edit-limit-event|edit-link-select|edit-log-select|edit-main-book|edit-review|edit-suggest-book|edit-time-event|count|count-time|event-count|export|publisher)$",
        "destination": "/admin/:page",
        "type": 301
      },
      {
        "regex": "^/(?P<rest>(publisher/detail|epub-viewer)/.+)$",
        "destination": "/admin/:rest",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/admin/**",
        "destination": "/admin/index.html"
      },
      {
        "source": "**",
        "function": "web_book"
      }
    ]
  },
  "apphosting": [
    {
      "backendId": "bookchelin-web",
      "rootDir": "./nextjs-web",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "functions",
        "vue-project",
        "public",
        "scripts"
      ]
    }
  ]
}
