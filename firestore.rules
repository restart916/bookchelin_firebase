service cloud.firestore {
  match /databases/{database}/documents {
    // 리뷰는 누구나 읽을 수 있지만 모든 변경은 검증된 Cloud Functions를 거친다.
    match /book_reviews/{reviewId} {
      allow read: if true;
      allow write: if false;
    }

    // 신고와 제재 정보는 운영 데이터이므로 일반 클라이언트에 노출하지 않는다.
    match /review_reports/{reportId} {
      allow read, write: if false;
    }
    match /review_user_bans/{userId} {
      allow read, write: if false;
    }

    // 기존 서비스의 규칙은 아직 보안 부채로 남아 있다. 이번 변경에서는 리뷰 경로만
    // 우선 잠그고, 나머지 컬렉션의 동작은 기존과 동일하게 유지한다.
    match /{collection}/{document=**} {
      allow read, write: if collection != 'book_reviews'
        && collection != 'review_reports'
        && collection != 'review_user_bans';
    }
  }
}
